# Copy this file to .env and fill in the values
# .env is gitignored — never commit real secrets

# PostgreSQL
POSTGRES_USER=omphalos
POSTGRES_PASSWORD=change-me-strong-password

# JWT — minimum 32 characters, random string
JWT_SECRET=change-me-minimum-32-chars-random-string!!

# First-run admin account (only used when the database has no users yet)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Exposed port on the host (your reverse proxy points here)
API_PORT=8080

# CORS — set to your public frontend URL if hosted separately from the API
# Leave empty if React is served by the same ASP.NET Core process (default)
ALLOWED_ORIGIN=
